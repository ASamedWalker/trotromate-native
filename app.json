{
  "expo": {
    "name": "Troski",
    "slug": "troski",
    "version": "1.0.0",
    "description": "Know your trotro fare, beat the queue. Community-powered transit updates for Ghana.",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "troski",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f59e0b"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.troski.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Take photos for Trotro Tales to share with the community.",
        "NSPhotoLibraryUsageDescription": "Select photos from your library for Trotro Tales.",
        "NSPhotoLibraryAddUsageDescription": "Save photos to your library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#f59e0b"
      },
      "package": "com.troski.app",
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Select photos from your library for Trotro Tales.",
          "cameraPermission": "Take photos for Trotro Tales to share with the community."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#f59e0b"
        }
      ],
      "expo-splash-screen"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "d62638cb-9c06-4aac-8e00-cbf7598ed47f"
      },
      "router": {}
    },
    "owner": "swalker01"
  }
}
